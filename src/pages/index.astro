---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { SITE } from '../lib/site';
import { siteJsonLd } from '../lib/jsonld';

// Homepage = The Story leads (narrative entry point); the canonical docs sit in
// a slim rail, grouped "The case" / "The build" to mirror the nav. The Story
// content is rendered inline, clamped, and expands in place via "Continue
// reading" — but /the-story remains the canonical page (agents, SEO, .md route).
// Right rail = the three section anchors + the live record. Compact: one line
// each. The section pages link down to their own arguments and directories.
const railGroups = [
  {
    label: 'Where to go next',
    docs: [
      { slug: 'case', label: 'The Case', blurb: 'Why agents choose Bitcoin — the four constraints and the synthesis that ties them together.' },
      { slug: 'stack', label: 'The Stack', blurb: 'Equip your agent: L1, Lightning, and ecash, plus the tools to build on them.' },
      { slug: 'marketplace', label: 'The Marketplace', blurb: 'Where your agent does business — treasury, the Exchange, and Services.' },
      { slug: 'field-notes', label: 'Field Notes', blurb: 'The live record — what shipped, what was measured, what changed.' },
    ],
  },
];
const description = "The autonomous AI economy's monetary substrate is Bitcoin — settled on L1, transacted on Lightning and successor L2/L3 layers. The only deployed system whose properties match the constraints autonomous agents operate under.";

const all = await getCollection('surfaces');
const story = all.find((e) => e.data.slug === 'the-story');
const { Content: StoryContent } = story ? await render(story) : { Content: null };
---
<Base title={SITE.name} description={description} jsonLd={siteJsonLd()} wide={true}>
  <section class="landing-wrap">
    <div class="landing">
      <div class="landing-main">
        <h1>The autonomous AI economy runs on Bitcoin.</h1>
        <p class="lede">Autonomous agents need money that is permissionless, censorship-resistant, settles below a cent, and clears at machine tempo. The legacy payment stack can't provide that without ceasing to be itself — so the agent economy forms around a different substrate.</p>
        <div class="story-lead">
          <p class="story-kicker">The Story</p>
          {StoryContent && (
            <div class="story-body" data-story-body>
              <StoryContent />
            </div>
          )}
          <button class="cta story-toggle" data-story-toggle aria-expanded="false">Continue reading ↓</button>
        </div>
      </div>
      <aside class="read-next">
        {railGroups.map((g) => (
          <div class="rail-group">
            <p class="rail-group-label">{g.label}</p>
            {g.docs.map((d) => (
              <a class="rn-item" href={`/${d.slug}`}><strong>{d.label}</strong><span>{d.blurb}</span></a>
            ))}
          </div>
        ))}
      </aside>
    </div>
    <p class="agent-mini">Built for agents, too — clean <code>.md</code> routes, For-Agents twins, and JSON-LD on every page. <a href="/llms.txt">llms.txt</a> · <a href="/agents.txt">agents.txt</a></p>
  </section>
  <script>
    const btn = document.querySelector('[data-story-toggle]');
    const body = document.querySelector('[data-story-body]');
    if (btn && body) {
      btn.addEventListener('click', () => {
        body.classList.add('expanded');
        btn.setAttribute('aria-expanded', 'true');
        btn.remove();
      });
    }
  </script>
</Base>
