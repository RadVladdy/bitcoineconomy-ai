---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE } from '../../lib/site';

// /services/directory — the service-card directory. (NOTE: this lives at
// /services/directory, not /services/index, because the Services *surface*
// slug is `services` and already renders at /services via [slug].astro at the
// site root — an index.astro here would collide. The detail pages
// /services/{slug} sit one level deeper and do not collide.)
//
// Services are tools-like: name + tagline. Grouped by `category`,
// featured-first within each group.
const all = await getCollection('services');
const cards = all
  .map((e) => e.data)
  .sort(
    (a, b) =>
      Number(b.featured) - Number(a.featured) ||
      a.order - b.order ||
      a.name.localeCompare(b.name),
  );

const groupMap = new Map<string, typeof cards>();
for (const c of cards) {
  const key = c.category ?? 'other';
  if (!groupMap.has(key)) groupMap.set(key, []);
  groupMap.get(key)!.push(c);
}
const groups = Array.from(groupMap, ([key, items]) => ({ key, items }));

const description =
  'A directory of services an agent buys or sells on the Bitcoin stack: inference marketplaces, payment bridges, and other live deployments — what each is, how payment settles, and its KYC posture, with verified links. Grouped by category.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Services — what an agent buys and sells on the Bitcoin stack',
  url: `${SITE.url}/services/directory`,
  description,
  isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url },
};
---
<Base title="Services directory" description={description} current="services" canonical="/services/directory" jsonLd={jsonLd} wide={true}>
  <div class="tools-intro">
    <h1>Services</h1>
    <p class="subtitle">What an agent actually buys and sells on the Bitcoin stack.</p>
    <p>Each card is a live service an agent can consume or offer for Bitcoin — what it is, how payment settles, and what (if any) identity it asks for. This is the directory; the narrative surface is <a href="/services">Services</a>, and the section overview is <a href="/marketplace">The Marketplace</a>.</p>
    <p class="tools-agent-note">Building agent flows? Each card has a clean <code>.md</code> route and structured <code>Service</code> JSON-LD. Payment and KYC fields move fast — confirm against the provider before you depend on them.</p>
  </div>

  {groups.map((g) => (
    <section class="tool-layer" aria-label={g.key}>
      <h2 class="tool-layer-h">{g.key}</h2>
      <div class="surface-grid">
        {g.items.map((c) => (
          <a class="surface-card tool-card" href={`/services/${c.slug}`}>
            <h3>{c.name}</h3>
            <p>{c.tagline}</p>
            <span class="tool-card-tags">
              {c.featured && <span class="tool-tag">featured</span>}
              <span class="tool-tag tool-tag-type">{c['tool-type']}</span>
              <span class="tool-tag tool-tag-type">{c.category}</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  ))}

  {groups.length === 0 && (
    <p class="tools-empty">Service cards are being drafted. Check back shortly.</p>
  )}
</Base>
