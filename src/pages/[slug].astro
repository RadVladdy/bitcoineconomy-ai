---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { TWIN, HUMAN_OF, isAgentSlug, HUMAN_NAV } from '../lib/site';
import { surfaceJsonLd } from '../lib/jsonld';

export async function getStaticPaths() {
  const all = await getCollection('surfaces');
  return all.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const agent = isAgentSlug(d.slug);
// The Story is a pure narrative — no subtitle, no meta badges (just the title + story).
const isStory = d.surface === 'the-story';
// `current` highlights the human surface in the nav (FA pages map to their human twin).
const humanSlug = agent ? HUMAN_OF[d.slug] : d.slug;
const navLabel = HUMAN_NAV.find((s) => s.slug === humanSlug)?.label ?? d.title;

// Cross-track twin link.
const twinSlug = agent ? HUMAN_OF[d.slug] : TWIN[d.slug];
const twinLabel = agent ? `${navLabel} (human narrative)` : `${navLabel} — For Agents`;

// Directory surfaces (Exchange, Services) render their card collection as tiles
// above the prose — the same tile component as /tools — for a consistent
// look-and-feel. Grouped by category; exchange tiles carry a facts row.
const EX_GROUPS = [
  { label: 'Non-custodial, no-KYC swaps', cats: ['noncustodial-swap'] },
  { label: 'Custodial — Bitcoin-only', cats: ['custodial-bitcoin-only'] },
  { label: 'Custodial — multi-asset', cats: ['custodial-multi-asset'] },
];
const SV_GROUPS = [
  { label: 'Agent-native services (A2A)', cats: ['machine-work-marketplace', 'inference-marketplace', 'inference-gateway'] },
  { label: 'Off-the-shelf services (A2B)', cats: ['payments-bridge', 'vpn-privacy'] },
];
let tileGroups: { label: string; items: any[] }[] = [];
let tileColl = '';
if (d.slug === 'exchange' || d.slug === 'services') {
  tileColl = d.slug === 'exchange' ? 'exchanges' : 'services';
  const cards = (await getCollection(d.slug === 'exchange' ? 'exchanges' : 'services'))
    .map((e) => e.data as any)
    .sort((a, b) => Number(b.featured) - Number(a.featured) || (a.order ?? 0) - (b.order ?? 0));
  const groups = d.slug === 'exchange' ? EX_GROUPS : SV_GROUPS;
  tileGroups = groups
    .map((g) => ({ label: g.label, items: cards.filter((c) => g.cats.includes(c.category)) }))
    .filter((g) => g.items.length);
}
const isDirectory = tileGroups.length > 0;
const lightLabel = (v: any) => (v === true ? 'Lightning' : typeof v === 'string' ? `${v} Lightning` : 'on-chain only');
const exFacts = (c: any) => [c.custody, c.kyc === 'none' ? 'no KYC' : 'KYC required', lightLabel(c.lightning)].filter(Boolean).join(' · ');

const jsonLd = surfaceJsonLd({
  slug: d.slug,
  title: d.title,
  description: d.description,
  audience: d.audience,
  type: d.type,
  created: d.created,
  'last-updated': d['last-updated'],
  'claims-index': d['claims-index'],
});

const fmt = (date: Date) => date.toISOString().slice(0, 10);
const mdPath = `/${d.slug}.md`;
const twinPath = twinSlug ? `/${twinSlug}` : '';
const tldrParas = (d['agent-tldr'] ?? '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
---
<Base
  title={d.title}
  description={d.description}
  current={humanSlug}
  canonical={`/${d.slug}`}
  jsonLd={jsonLd}
  wide={isDirectory}
>
  <article class="prose">
    <h1>{d.title}</h1>
    {d.description && !isStory && <p class="subtitle">{d.description}</p>}
    {!isStory && (
      <div class="page-meta">
        <span class="badge">{agent ? 'For Agents · machine-readable' : 'For Humans'}</span>
        {d['epistemic-status'] && <span class="badge">{d['epistemic-status']}</span>}
        <span class="badge">Updated {fmt(d['last-updated'])}</span>
        {twinSlug && (
          <a class="badge agents" href={`/${twinSlug}`}>{agent ? '↩ Human version' : '→ For Agents'}</a>
        )}
      </div>
    )}

    {agent && (
      <section class="tldr" aria-label="TL;DR summary">
        <h2>TL;DR</h2>
        {tldrParas.map((para) => <p>{para}</p>)}
      </section>
    )}

    {isDirectory && (
      <div class="surface-tiles">
        {tileGroups.map((g) => (
          <section class="tool-layer" aria-label={g.label}>
            <h2 class="tool-layer-h">{g.label}</h2>
            <div class="surface-grid">
              {g.items.map((c) => (
                <a class="surface-card tool-card" href={`/${tileColl}/${c.slug}`}>
                  <h3>{c.title ?? c.name}</h3>
                  <p>{d.slug === 'exchange' ? exFacts(c) : c.tagline}</p>
                  <span class="tool-card-tags">
                    {c.featured && <span class="tool-tag">★ standout</span>}
                    <span class="tool-tag tool-tag-type">{d.slug === 'exchange' ? (c.kyc === 'none' ? 'no-KYC' : 'KYC') : c['tool-type']}</span>
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))}
        <p class="surface-tiles-note">Each card opens its full profile. The deeper write-up follows below.</p>
      </div>
    )}

    <div class={isDirectory ? 'surface-prose-narrow' : ''}>
      <Content />
    </div>

    <aside class="twin-callout">
      {twinSlug ? (
        <p set:html={agent
          ? `Prefer the narrative? Read the <a href="${twinPath}">${twinLabel}</a>. Raw markdown for this page: <a href="${mdPath}">${mdPath}</a>.`
          : `Reading as an agent, or want the claims-indexed version? See the <a href="${twinPath}">${twinLabel}</a> — a claims-indexed restructuring with definitions and falsification conditions, alongside the site's shared <a href="/llms.txt"><code>llms.txt</code></a> / <a href="/agents.txt"><code>agents.txt</code></a> / JSON-LD infrastructure. Raw markdown for this page: <a href="${mdPath}">${mdPath}</a>.`} />
      ) : (
        <p set:html={`The Story is human-only by design. The machine-structured argument is <a href="/case-for-agents">The Case — For Agents</a>; site-wide agent infrastructure lives at <a href="/llms.txt">/llms.txt</a> and <a href="/agents.txt">/agents.txt</a>. Raw markdown for this page: <a href="${mdPath}">${mdPath}</a>.`} />
      )}
    </aside>
  </article>
</Base>
